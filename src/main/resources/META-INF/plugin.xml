<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>com.kody.backgroundImagePlus</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>BackgroundImagePlus</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://github.com/kody-code">Kody</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        一个简单易用的IntelliJ IDEA背景图片插件。<br>
        支持从指定文件夹自动循环切换壁纸，可调节透明度和切换间隔。<br>
        <em>开箱即用，无需复杂配置！</em>
        <ul>
            <li>🖼️ 自动壁纸切换功能</li>
            <li>⚙️ 简洁的配置界面</li>
            <li>🎛️ 精确的透明度和间隔调节</li>
            <li>🌍 中英文双语支持</li>
        </ul>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.compose</depends>
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="appearance"
                instance="com.kody.backgroundimageplus.config.BackgroundImageConfigurable"
                id="com.kody.backgroundimageplus.config.BackgroundImageConfigurable"
                key="config.background.title"/>
        <applicationService
                serviceImplementation="com.kody.backgroundimageplus.config.BackgroundImageSettings"/>
        <postStartupActivity implementation="com.kody.backgroundimageplus.listener.StartupActivity"/>
    </extensions>

    <!-- Actions -->
    <actions>
        <group id="BackgroundImagePlus.Menu"
               popup="true">
            <add-to-group group-id="ViewMenu" anchor="last"/>
            <action id="ToggleAutoSwitch"
                    class="com.kody.backgroundimageplus.actions.ToggleAutoSwitchAction"/>
            <action id="ShowNextImage"
                    class="com.kody.backgroundimageplus.actions.ShowNextImageAction"/>
            <action id="ClearBackground"
                    class="com.kody.backgroundimageplus.actions.ClearBackgroundAction"/>
            <action id="Random"
                    class="com.kody.backgroundimageplus.actions.ShowRandomImageAction"/>
        </group>
    </actions>
</idea-plugin>